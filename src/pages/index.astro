    background-attachment: fixed; */
			/* Background Inspired BY Temani Afif - Dark Mode */
			background-color: #16161a;

			/* Scrolling */
			scrollbar-width: thin;
			scrollbar-color: transparent transparent;
			overflow: -moz-scrollbars-none;
			-ms-overflow-style: none;
			/* Scrolling */
		}

		.me {
			height: 100vh;
			width: 100%;
			margin: auto;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 35px;
			color: #94a1b2;
			gap: 20px;
		}

		.me div {
			width: 50%;
		}

		nav {
			width: 80%;
			height: 80px;
			position: fixed;
			top: 0;
			color: #7f5af0;
			display: flex;
			justify-content: space-around;
			align-items: center;
			border-radius: 0 0 10px 10px;
			z-index: 999;
			animation: headerEffect linear both;
			animation-timeline: scroll(root block);
			animation-range: 0 500px;
		}

		@keyframes headerEffect {
			to {
				background: rgba(255, 255, 255, 0.3);
				backdrop-filter: blur(4px);
				/* width: 50%; */
				color: #000;
			}
		}

		nav p {
			height: 0px;
			overflow: hidden;
			text-align: center;
			color: #000;
			font-weight: bold;
			animation: headerText linear both;
			animation-timeline: scroll(root block);
			animation-range: 0 500px;
		}

		@keyframes headerText {
			to {
				height: auto;
			}
		}

		nav img {
			width: 55px;
			border-radius: 50%;
		}
		
		nav ul svg {
			width: 40px;
		}

		nav a {
			color: inherit;
			transition: color 0.4s ease;

			&:hover {
				color: #2cb67d;
			}
		}

		nav ul {
			list-style: none;
			display: flex;
			font-size: 35px;
		}

		nav svg {
			width: 45px;
			height: auto;
		}

		.profile-pic {
			width: 250px;
			height: 250px;
			border-radius: 10px;
			object-fit: cover;
			margin-bottom: 20px;
		}

		h1,
		h2,
		p {
			margin: 0;
		}

		section {
			height: 80vh;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}

		section:nth-child(4) {
			width: 80%;
			height: auto;
		}

		.contentServices {
			width: 90%;
			height: 50%;
			margin: auto;
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 20px;
		}

		.contentServices img {
			width: 120px;
			margin: 20px;
		}

		.itemS {
			text-align: center;
		}

		.project-grid {
			max-width: 1050px;
			width: 100%;
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			grid-template-rows: repeat(2, 300px);
			gap: 20px;
			margin-top: 20px;
		}

		.project-card {
			position: relative;
			overflow: hidden;
			border-radius: 10px;
			transition: opacity 1s;
			background-color: #22272b;
			color: #e0e0e0;
			animation: revelImg linear both;
			animation-timeline: view();
			animation-range: entry 50% cover 10%;
		}

		@keyframes revelImg {
			from {
				opacity: 0;
			}

			to {
				opacity: 1;
			}
		}

		.project-card .default-text {
			position: absolute;
			bottom: 0;
			left: 0;
			right: 0;
			background: #271b4a;
			color: white;
			padding: 10px;
			text-align: center;
		}

		.project-card .buttons {
			display: flex;
			justify-content: space-evenly;
