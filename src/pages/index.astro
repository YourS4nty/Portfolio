	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
			text-wrap: balance;
			overflow-x: hidden;
		}

		body::-webkit-scrollbar {
			display: none;
		}

		.scroll {
			width: 7px;
			background: linear-gradient(to top, #7f5af0, transparent);
			border-radius: 0 0 10px 10px;
			position: fixed;
			top: 0;
			right: 0;
			animation: scrolling auto linear;
			animation-timeline: scroll(root block);
		}

		@keyframes scrolling {
			from {
				height: 0%;
			}

			to {
				height: 100%;
			}
		}

		a,
		i {
			overflow: hidden;
		}

		body {
			font-family: "Arial", sans-serif;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			min-height: 100vh;
			color: #b8c1ec;
			/* Background Inspired BY Temani Afif - Dark Mode */
